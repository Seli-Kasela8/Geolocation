{
    "name": "Post to Google My Business from Instagram",
    "flow": [
        {
            "id": 1,
            "module": "instagram-business:WatchMedia",
            "version": 1,
            "parameters": {},
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": -463,
                    "y": -15,
                    "name": "Wait for new publication"
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    },
                    {
                        "name": "accountId",
                        "type": "select",
                        "label": "Page",
                        "required": true
                    },
                    {
                        "name": "limit",
                        "type": "uinteger",
                        "label": "Limit",
                        "required": true
                    }
                ]
            }
        },
        {
            "id": 2,
            "module": "google-my-business:uploadAMediaItem",
            "version": 1,
            "parameters": {},
            "filter": {
                "name": "Does the post have an image?",
                "conditions": [
                    [
                        {
                            "a": "{{1.media_url}}",
                            "b": "",
                            "o": "exist"
                        }
                    ]
                ]
            },
            "mapper": {},
            "metadata": {
                "designer": {
                    "x": -33,
                    "y": -14,
                    "name": "Upload image to GMB"
                },
                "restore": {},
                "parameters": [
                    {
                        "name": "__IMTCONN__",
                        "type": "account",
                        "label": "Connection",
                        "required": true
                    }
                ],
                "expect": [
                    {
                        "name": "select",
                        "type": "select",
                        "label": "Enter a Location Name",
                        "required": true,
                        "validate": {
                            "enum": [
                                "map",
                                "list"
                            ]
                        }
                    },
                    {
                        "name": "url",
                        "type": "text",
                        "label": "URL address of media item",
                        "required": true
                    },
                    {
                        "name": "mediaFormat",
                        "type": "select",
                        "label": "Media format",
                        "required": true,
                        "validate": {
                            "enum": [
                                "PHOTO",
                                "VIDEO"
                            ]
                        }
                    },
                    {
                        "name": "category",
                        "type": "select",
                        "label": "Category",
                        "required": true,
                        "validate": {
                            "enum": [
                                "COVER",
                                "PROFILE",
                                "LOGO",
                                "EXTERIOR",
                                "INTERIOR",
                                "PRODUCT",
                                "AT_WORK",
                                "FOOD_AND_DRINK",
                                "MENU",
                                "COMMON_AREA",
                                "ROOMS",
                                "TEAMS",
                                "ADDITIONAL"
                            ]
                        }
                    },
                    {
                        "name": "account",
                        "type": "select",
                        "label": "Account name",
                        "required": true
                    },
                    {
                        "name": "location",
                        "type": "select",
                        "label": "Location name",
                        "required": true
                    }
                ]
            }
        }
    ],
    "metadata": {
        "instant": false,
        "version": 1,
        "scenario": {
            "roundtrips": 1,
            "maxErrors": 3,
            "autoCommit": true,
            "autoCommitTriggerLast": true,
            "sequential": false,
